{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faultwitness.local/schemas/bootstrap/toolchain-lock.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "tools"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "tools": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sops", "age"],
      "properties": {
        "sops": {"$ref": "#/$defs/tool"},
        "age": {
          "allOf": [
            {"$ref": "#/$defs/tool"},
            {
              "type": "object",
              "required": ["executables"],
              "properties": {
                "executables": {
                  "type": "object",
                  "additionalProperties": {"$ref": "#/$defs/sha256"},
                  "minProperties": 2
                }
              }
            }
          ]
        }
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "platform", "url", "sha256", "verification"],
      "properties": {
        "version": {"pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "platform": {"const": "windows-amd64"},
        "url": {"type": "string", "pattern": "^https://github\\.com/"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "verification": {"enum": ["official-release-checksums", "github-release-asset-digest"]},
        "executables": {
          "type": "object",
          "additionalProperties": {"$ref": "#/$defs/sha256"}
        }
      }
    }
  }
}
