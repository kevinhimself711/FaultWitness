{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faultwitness.local/schemas/bootstrap/secret-config.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "store_location", "encrypted_store_required", "plaintext_repository_store_forbidden", "secrets", "rotation_trigger", "public_evidence"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "store_location": {"const": "outside_repository"},
    "encrypted_store_required": {"const": true},
    "plaintext_repository_store_forbidden": {"const": true},
    "secrets": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "type", "lifecycle_policy", "verification_owner"],
        "properties": {
          "name": {"pattern": "^[a-z]+(?:[._][a-z_]+)+$"},
          "type": {"enum": ["host", "port", "username", "password", "api_key"]},
          "lifecycle_policy": {"const": "long_lived"},
          "verification_owner": {"type": "string", "pattern": "^I-[0-9]{4}$"}
        }
      }
    },
    "rotation_trigger": {"const": "confirmed_compromise_or_operator_revocation"},
    "public_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed", "forbidden"],
      "properties": {
        "allowed": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "forbidden": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
      }
    }
  }
}
