{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faultwitness.local/schemas/governance/requirement-registry.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "requirements"],
  "properties": {
    "schema_version": {"pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "statement", "mandatory", "priority", "source_ids", "roles", "gates", "status"],
        "properties": {
          "id": {"pattern": "^REQ-[A-Z]+-[0-9]{3}$"},
          "statement": {"type": "string", "minLength": 10},
          "mandatory": {"type": "boolean"},
          "priority": {"enum": ["P0", "P1", "P2"]},
          "source_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "roles": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "gates": {"type": "array", "items": {"pattern": "^G[0-9]{2}$"}, "uniqueItems": true},
          "status": {"enum": ["proposed", "accepted", "deferred", "rejected"]}
        },
        "allOf": [
          {"if": {"properties": {"mandatory": {"const": true}}}, "then": {"properties": {"source_ids": {"minItems": 1}}}}
        ]
      }
    }
  }
}
