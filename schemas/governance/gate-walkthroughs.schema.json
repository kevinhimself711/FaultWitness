{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faultwitness.local/schemas/governance/gate-walkthroughs.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "gate", "candidate_kind", "walkthroughs"],
  "properties": {
    "schema_version": {"pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "gate": {"const": "G00"},
    "candidate_kind": {"const": "design_contract"},
    "walkthroughs": {
      "type": "array",
      "minItems": 14,
      "maxItems": 14,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "scenario", "source_binding", "assertion", "status"],
        "properties": {
          "id": {"pattern": "^W-G00-[0-9]{3}$"},
          "scenario": {"type": "string", "minLength": 5},
          "source_binding": {"pattern": "^W-ARCH-[0-9]{3}$"},
          "assertion": {"type": "string", "minLength": 20},
          "status": {"const": "pass"}
        }
      }
    }
  }
}
