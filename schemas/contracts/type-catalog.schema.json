{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faultwitness.local/schemas/contracts/type-catalog.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "types"],
  "properties": {
    "schema_version": {"pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "types": {
      "type": "array", "minItems": 20,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["name", "owner_component", "authoritative_store", "version", "fields", "invariants"],
        "properties": {
          "name": {"pattern": "^[A-Z][A-Za-z0-9]+$"},
          "owner_component": {"pattern": "^CMP-[A-Z0-9-]+$"},
          "authoritative_store": {"oneOf": [{"type": "string", "pattern": "^STORE-[A-Z0-9-]+$"}, {"type": "null"}]},
          "version": {"pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
          "fields": {
            "type": "array", "minItems": 2,
            "items": {
              "type": "object", "additionalProperties": false,
              "required": ["name", "type", "required", "source", "sensitive"],
              "properties": {
                "name": {"pattern": "^[a-z][a-z0-9_]+$"},
                "type": {"type": "string", "minLength": 2},
                "required": {"type": "boolean"},
                "source": {"enum": ["oidc_claim", "request", "system", "derived", "reference"]},
                "sensitive": {"type": "boolean"}
              }
            }
          },
          "invariants": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 8}}
        }
      }
    }
  }
}
